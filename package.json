  "dependencies": {
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "react-test-renderer": "^19.2.0"
  }
